# Do not put real secrets in this file.

# Production env vars.
GITHUB_OWNER=kohei321dev
DATABASE_URL=
AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GROK_API_KEY=

# Optional AI model tuning.
# Current xAI docs recommend Grok 4.3 for general text.
# Keep this as an env var so we can switch models without code changes.
GROK_MODEL=grok-4.3
# AI review is a simple coaching task, so disable reasoning by default.
GROK_REASONING_EFFORT=none

# GitHub OAuth callback URL:
#   https://your-vercel-url/api/auth/callback/github

# Local UI verification only. This is ignored when NODE_ENV=production.
DEV_AUTH_BYPASS=1

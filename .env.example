# Do not put real secrets in this file.

# Production env vars.
GITHUB_OWNER=kohei321dev
DATABASE_URL=
AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OWNER_AI_KEY=
OWNER_AI_MODEL=grok-4.3
VIEWER_AI_KEY=
VIEWER_AI_MODEL=claude-haiku-4-5-20251001

# Server-side xAI speech generation reuses OWNER_AI_KEY. Keep all keys out of the browser.
SAYDECK_TTS_VOICE=eve
SAYDECK_TTS_SPEED=1.0

# Required for private audio/APKG storage in Vercel Production.
BLOB_READ_WRITE_TOKEN=

# AI guardrails:
# - OWNER_AI_MODEL only allows grok-4.3.
# - VIEWER_AI_MODEL only allows claude-haiku-4-5-20251001.
# - Owner Grok reasoning effort is fixed to none in code.

# GitHub OAuth callback URL:
#   https://your-vercel-url/api/auth/callback/github

# Local UI verification only. This is ignored when NODE_ENV=production.
DEV_AUTH_BYPASS=1

# Do not put real secrets in this file.

# Set one of these after deciding the AI provider.
GROQ_API_KEY=
XAI_API_KEY=

# Used by the app to choose the provider adapter.
# Allowed examples: groq, xai
AI_PROVIDER=groq

# Optional owner allowlist for the first authenticated version.
OWNER_EMAIL=
OWNER_GITHUB_USERNAME=

